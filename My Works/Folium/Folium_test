

import folium
import pandas as pd
import requests

# বাংলাদেশের divisions GeoJSON (internet থেকে)
# নিজে test করার জন্য Bangladesh GeoJSON দরকার
# এখানে example হিসেবে World countries ব্যবহার করছি

url = "https://raw.githubusercontent.com/python-visualization/folium/master/examples/data/world-countries.json"

# Example data — দেশের জনসংখ্যা
data = pd.DataFrame({
    "country": ["Bangladesh", "India", "Pakistan", "China", "USA"],
    "population": [170000000, 1400000000, 220000000, 1400000000, 330000000]
})

m = folium.Map(location=[23.8103, 90.4125], zoom_start=2)

folium.Choropleth(
    geo_data=url,                    # GeoJSON
    name="Population",
    data=data,
    columns=["country", "population"],  # কোন column match করবে
    key_on="feature.properties.name",   # GeoJSON-এ দেশের নাম কোথায়
    fill_color="YlOrRd",             # color scale
    fill_opacity=0.7,
    line_opacity=0.2,
    legend_name="জনসংখ্যা"
).add_to(m)

folium.LayerControl().add_to(m)
m.save("choropleth.html")